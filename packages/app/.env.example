# Storage. Dev/test defaults to SQLite in packages/app/.data when both values are unset.
# Production requires STORAGE_DRIVER explicitly; SQLite also requires an explicit writable DATA_DIR.
# STORAGE_DRIVER=sqlite
# DATA_DIR=.data

# Optional Azure driver. Set STORAGE_DRIVER=azure, then configure one of the following.
# Preferred: set the account NAME and use the Web App's managed identity (grant it
# "Storage Blob Data Contributor" + "Storage Table Data Contributor"). No secret.
# AZURE_STORAGE_ACCOUNT=
# Alternative to managed identity: a full connection string (a secret).
# AZURE_STORAGE_CONNECTION_STRING=

# Trusted-header authentication. Production requires AUTH_MODE=header and must only expose Stela
# through a proxy that authenticates users, strips client-supplied identity headers, and sets these.
AUTH_MODE=header
AUTH_HEADER_ID=X-Forwarded-User
# AUTH_HEADER_NAME=X-Forwarded-Name
# AUTH_HEADER_EMAIL=X-Forwarded-Email
# Optional browser login endpoint. Stela redirects there verbatim when an anonymous page is opened.
# AUTH_LOGIN_URL=https://auth.example.com/login

# Azure App Service Easy Auth alternative. This preset uses x-ms-client-principal and its built-in
# /.auth/login/aad flow; AUTH_HEADER_* and AUTH_LOGIN_URL are not used by the preset.
# AUTH_PRESET=easyauth

# Publish API key for the MCP/CLI. The MCP server sends this; the app checks it.
# REQUIRED in production — the app fails closed (no dev fallback) when not running in dev.
STELA_API_KEY=dev-publish-key

# Identity attributed as the owner when publishing via the API key (v1; OAuth later).
STELA_API_USER_ID=dev-user-0001
STELA_API_USER_NAME=Dev User
STELA_API_USER_EMAIL=dev@example.com

# Max request body for the node adapter — rejects oversized uploads before buffering.
# (The publish schema also caps artifact HTML at 10 MB.)
BODY_SIZE_LIMIT=12000000

# Production only: public origin so adapter-node (behind a reverse proxy) computes
# url.origin correctly — publish URLs and the same-origin CSRF check depend on it.
# ORIGIN=https://stela.example.com
